# Скопируйте в .env.local для локального ЛК и статистики.
# Без этой переменной приложение работает как раньше (статьи/задачи доступны всем).
VITE_API_URL=http://localhost:3000

# Статьи и полные задачи из db.json (json-server).
# В dev по умолчанию запросы идут на /content-api (прокси Vite → localhost:3001, без CORS).
# В production-сборке без этой строки — прямой URL http://localhost:3001.
# Запуск json-server: из папки front — npm run mock:server
# Пустая строка = не ходить в API, только встроенные TASKS/THEORIES.
# VITE_CONTENT_API_URL=
